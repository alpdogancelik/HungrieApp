rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isRestaurantStaffFor(restaurantId) {
      return isSignedIn()
        && exists(/databases/$(database)/documents/restaurantStaff/$(request.auth.uid))
        && get(/databases/$(database)/documents/restaurantStaff/$(request.auth.uid)).data.restaurantId == restaurantId;
    }

    function isRestaurantOwnerFor(restaurantId) {
      return isSignedIn()
        && restaurantId is string
        && exists(/databases/$(database)/documents/restaurants/$(restaurantId))
        && (
          get(/databases/$(database)/documents/restaurants/$(restaurantId)).data.ownerId == request.auth.uid
          || (
            request.auth.token.email != null
            && (
              get(/databases/$(database)/documents/restaurants/$(restaurantId)).data.ownerEmail == request.auth.token.email
              || (
                get(/databases/$(database)/documents/restaurants/$(restaurantId)).data.managerEmails is list
                && request.auth.token.email in get(/databases/$(database)/documents/restaurants/$(restaurantId)).data.managerEmails
              )
            )
          )
        );
    }

    function isDeliveredOrCompleted(status) {
      return status == "delivered" || status == "completed" || status == "teslim edildi";
    }

    function isValidRatingValue(value) {
      return (value is int || value is float)
        && value >= 1
        && value <= 5;
    }

    function isValidOrderReviewRatings(ratings) {
      return ratings is map
        && isValidRatingValue(ratings.speed)
        && isValidRatingValue(ratings.taste)
        && isValidRatingValue(ratings.value);
    }

    match /users/{userId} {
      allow read, write: if isSignedIn() && request.auth.uid == userId;

      match /addresses/{addressId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }

      match /pushTokens/{tokenId} {
        allow read, write: if isSignedIn() && request.auth.uid == userId;
      }
    }
    
    match /restaurantStaff/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow write: if false;
    }

    match /restaurants/{restaurantId}/pushTokens/{tokenId} {
      allow read, write: if isSignedIn()
        && request.auth.uid == get(/databases/$(database)/documents/restaurants/$(restaurantId)).data.ownerId;
    }

    match /orders/{orderId} {
      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.restaurantId is string;
      
      allow read: if isSignedIn()
        && (
          resource.data.userId == request.auth.uid
          || isRestaurantStaffFor(resource.data.restaurantId)
          || isRestaurantOwnerFor(resource.data.restaurantId)
        );

      allow update: if isSignedIn()
        && (
          (
            resource.data.userId == request.auth.uid
            && request.resource.data.diff(resource.data).changedKeys().hasOnly([
              "reminderPending",
              "reminderRequestedAt",
              "reminderRequestedAtMs",
              "reminderRequestedBy",
              "reminderSource",
              "updatedAt",
              "updatedAtMs"
            ])
            && request.resource.data.reminderRequestedBy == request.auth.uid
          )
          || (
            (
              isRestaurantStaffFor(resource.data.restaurantId)
              || isRestaurantOwnerFor(resource.data.restaurantId)
            )
            && request.resource.data.diff(resource.data).changedKeys().hasOnly([
              "status",
              "statusChangedAt",
              "statusChangedAtMs",
              "updatedAt",
              "updatedAtMs",
              "reminderPending",
              "reminderHandledAt",
              "reminderHandledAtMs",
              "acceptedAt",
              "acceptedAtMs",
              "readyAt",
              "readyAtMs",
              "outForDeliveryAt",
              "outForDeliveryAtMs",
              "deliveredAt",
              "deliveredAtMs",
              "canceledAt",
              "canceledAtMs",
              "rejectedAt",
              "rejectedAtMs"
            ])
          )
        );
    }

    match /restaurants/{restaurantId} {
      allow read: if true;
    }

    match /menus/{menuId} {
      allow read: if true;
    }

    match /categories/{categoryId} {
      allow read: if true;
    }

    match /reviews/{reviewId} {
      allow read: if true;

      allow create: if isSignedIn()
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.orderId is string
        && request.resource.data.restaurantId is string
        && request.resource.data.menuItemId is string
        && request.resource.data.menuItemName is string
        && (request.resource.data.rating is int || request.resource.data.rating is float)
        && request.resource.data.rating >= 1
        && request.resource.data.rating <= 5
        && reviewId == request.resource.data.orderId + "__" + request.resource.data.menuItemId + "__" + request.auth.uid
        && !exists(/databases/$(database)/documents/reviews/$(reviewId))
        && exists(/databases/$(database)/documents/orders/$(request.resource.data.orderId))
        && get(/databases/$(database)/documents/orders/$(request.resource.data.orderId)).data.userId == request.auth.uid
        && (
          get(/databases/$(database)/documents/orders/$(request.resource.data.orderId)).data.status == "delivered"
          || get(/databases/$(database)/documents/orders/$(request.resource.data.orderId)).data.status == "completed"
          || get(/databases/$(database)/documents/orders/$(request.resource.data.orderId)).data.status == "teslim edildi"
        );

      allow update, delete: if false;
    }

    match /orderReviews/{reviewId} {
      allow read: if resource.data.status == "published"
        || (
          isSignedIn() && (
            resource.data.userId == request.auth.uid
            || isRestaurantStaffFor(resource.data.restaurantId)
            || isRestaurantOwnerFor(resource.data.restaurantId)
          )
        );

      allow create: if isSignedIn()
        && request.resource.data.id == reviewId
        && request.resource.data.userId == request.auth.uid
        && request.resource.data.orderId is string
        && request.resource.data.restaurantId is string
        && request.resource.data.status == "published"
        && request.resource.data.itemsSnapshot is list
        && isValidOrderReviewRatings(request.resource.data.ratings)
        && isValidRatingValue(request.resource.data.averageRating)
        && reviewId == request.resource.data.orderId + "__" + request.auth.uid
        && !exists(/databases/$(database)/documents/orderReviews/$(reviewId))
        && exists(/databases/$(database)/documents/orders/$(request.resource.data.orderId))
        && get(/databases/$(database)/documents/orders/$(request.resource.data.orderId)).data.userId == request.auth.uid
        && get(/databases/$(database)/documents/orders/$(request.resource.data.orderId)).data.restaurantId == request.resource.data.restaurantId
        && isDeliveredOrCompleted(get(/databases/$(database)/documents/orders/$(request.resource.data.orderId)).data.status);

      allow update: if isSignedIn()
        && (
          isRestaurantStaffFor(resource.data.restaurantId)
          || isRestaurantOwnerFor(resource.data.restaurantId)
        )
        && request.resource.data.diff(resource.data).changedKeys().hasOnly([
          "status",
          "updatedAt"
        ])
        && (request.resource.data.status == "published" || request.resource.data.status == "hidden");

      allow delete: if false;
    }

    match /{document=**} {
      allow read, write: if false;
    }
  }
}
